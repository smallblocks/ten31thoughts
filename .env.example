# Ten31 Thoughts - Environment Configuration
# Copy this file to .env and fill in your values

# ─── LLM API Keys (at least one required) ───
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Local Model (Ollama) ───
# If running Ollama locally on your StartOS device
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ─── Model Selection Per Task ───
# Analysis passes (complex extraction - use best available model)
TEN31_LLM_ANALYSIS_MODEL=claude-sonnet-4-20250514

# Weekly synthesis (highest stakes output)
TEN31_LLM_SYNTHESIS_MODEL=claude-sonnet-4-20250514

# Chat responses (balance of quality and latency)
TEN31_LLM_CHAT_MODEL=claude-sonnet-4-20250514

# Embeddings (high volume, cost-sensitive)
TEN31_LLM_EMBEDDING_MODEL=text-embedding-3-small

# ─── Database ───
DATABASE_URL=sqlite:///data/ten31thoughts.db

# ─── Service Ports ───
# App: 8431, ChromaDB: 8432, Redis: 8433
